
# 2. `.gitignore`

```gitignore
# Node
node_modules/
dist/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# React / Vite
.vite/
coverage/

# .NET
bin/
obj/

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Rider / JetBrains
.idea/

# OS
.DS_Store
Thumbs.db

# Environment files
.env
.env.*
!.env.example

# Logs
logs/
*.log

# Generated files
*.cache
*.tmp